# Core application
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Keep false until the launch checklist and legal review are complete
SITE_INDEXABLE=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DEALEROS_DEMO_MODE=false
# Required when more than one active organisation shares a deployment
DEALEROS_PUBLIC_ORGANISATION_ID=

# Safe public fallback identity when Supabase is unavailable
NEXT_PUBLIC_DEALERSHIP_NAME=
NEXT_PUBLIC_DEALERSHIP_PHONE=
NEXT_PUBLIC_DEALERSHIP_EMAIL=
NEXT_PUBLIC_DEALERSHIP_ADDRESS=

# Vehicle lookup
VEHICLE_LOOKUP_PROVIDER=mock
DVLA_VES_API_KEY=
DVLA_VES_BASE_URL=https://driver-vehicle-licensing.api.gov.uk/vehicle-enquiry/v1/vehicles

# Auto Trader Connect — requires an authorised agreement
AUTOTRADER_CLIENT_ID=
AUTOTRADER_CLIENT_SECRET=
AUTOTRADER_ADVERTISER_ID=
AUTOTRADER_API_BASE_URL=
AUTOTRADER_WEBHOOK_SECRET=

# Communications (SMS delivery is not implemented in this release)
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM=

# Operations
CRON_SECRET=

# Development seed controls (never point these at production)
DATABASE_URL=
SUPABASE_DB_URL=
ALLOW_REMOTE_SEED=false

# Optional live Playwright journey
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
